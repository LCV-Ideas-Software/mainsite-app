{
  "name": "mainsite-frontend",
  "private": true,
  "version": "3.7.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "biome": "biome check .",
    "biome:write": "biome check --write .",
    "test": "node ./scripts/run-vitest.mjs run",
    "test:ui": "node ./scripts/run-vitest.mjs --ui",
    "test:e2e": "playwright test",
    "preview": "vite preview",
    "format": "biome format --write src",
    "knip": "knip",
    "stats": "ANALYZE=true vite build",
    "prepare": "husky"
  },
  "dependencies": {
    "@cloudflare/workers-types": "^5.20260721.1",
    "@tanstack/react-query": "^5.101.3",
    "dompurify": "^3.4.12",
    "lucide-react": "^1.25.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.5",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@tanstack/react-query-devtools": "^5.101.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.4",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/ui": "^4.1.10",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "knip": "^6.27.0",
    "lint-staged": "^17.1.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.65.0",
    "vite": "^8.1.5",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.10"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "biome format --write",
      "eslint --fix"
    ]
  },
  "overrides": {
    "minimatch@^10.0.0": {
      "brace-expansion": "5.0.7"
    },
    "minimatch@^5.0.0": {
      "brace-expansion": "2.1.2"
    },
    "picomatch": "4.0.4",
    "vite": "$vite",
    "serialize-javascript": "^7.0.5",
    "ws": "8.20.1",
    "source-map": "^0.7.6",
    "workbox-build": {
      "glob": "13.0.6"
    },
    "sourcemap-codec": "npm:@jridgewell/sourcemap-codec@1.5.5",
    "@babel/core": "7.29.6",
    "fast-uri": "4.1.1"
  }
}
